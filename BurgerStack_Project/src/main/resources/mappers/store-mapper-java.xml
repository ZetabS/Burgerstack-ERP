<?xml version="1.0" encoding="UTF-8" ?>
    <!--
    mapper DTD 선언
    점주 존재 여부 확인
    점포 등록
    전체 자재 기준 점포 재고 생성
    관리자 점포 목록 조회
    -->
    <!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
    "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
    <mapper namespace="com.kh.burgerstack.store.StoreMapper">
    <select id="findStoreIdByOwnerUserNo" >
         SELECT STORE_ID
           FROM STORES
          WHERE OWNER_USER_NO = #{ownerUserNo}
            AND STATUS = 'OPEN'
    </select>
</mapper>

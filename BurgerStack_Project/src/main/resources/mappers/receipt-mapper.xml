<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="ReceiptMapper">

	<!-- 입고예정목록 총 갯수를 구하는 쿼리문 -->
	<select id="getHistoryTotalCount" resultType="_int">
		SELECT COUNT(*)
          FROM PURCHASE_REQUESTS
        <!-- 
        WHERE STATUS = 'REQUESTED'
        AND STORE_ID = #{storeId} 
        -->
	</select>

    <!-- 입고 이력 목록 총 갯수를 구하는 쿼리문 -->
    <select id="getPlanTotalCount" resultType="_int">
        SELECT COUNT(*)
          FROM RECEIPTS
         <!-- WHERE STORE_ID = #{storeId} -->
    </select>

    <!-- 입고 예정 목록 리스트 조회 -->
    <select id="searchReceiptPlanList" resultType="Receipt">
    
    </select>

	
</mapper>


